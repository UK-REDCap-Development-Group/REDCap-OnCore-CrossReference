{
    "name": "ROCS - REDCap OnCore Sync",
    "description": "ROCS creates a dashboard in REDCap that connects OnCore data to REDCap data and allows a user to check that both sources match and allow for manual editing of records which do not match.",
    "namespace": "UKModules\\ROCS",
    "framework-version": 15,
    "authors": [
        {
            "name": "Noah Perry",
            "email": "noah.perry@uky.edu",
            "institution": "University of Kentucky CCTS"
        }
    ],
    "system-settings": [],
    "project-settings": [
        {
            "key": "token-url-desc",
            "name": "Please input the url for the OnCore OAuth Token API source you wish to use below. The URL should look something like this:<br> https://oncore.forteresearchapps.com/forte-platform-web/api/oauth/token.",
            "type": "descriptive",
            "required": true
        },
        {
            "key": "oncore-token-url",
            "name": "OnCore API Token URL",
            "type": "text",
            "required": true
        },
        {
            "key": "base-url-desc",
            "name": "Please input the base url for the OnCore API source you wish to use below. The URL should look something like this:<br> https://oncore.forteresearchapps.com/oncore-api/rest/.",
            "type": "descriptive",
            "required": true
        },
        {
            "key": "oncore-api-url",
            "name": "OnCore API Base URL",
            "type": "text",
            "requiured": true
        },
        {
            "key": "secret-client-desc",
            "name": "Below you should include the client secret and client id which was generated for your API connection.",
            "type": "descriptive"
        },
        {
            "key": "oncore-secret",
            "name": "OnCore Secret",
            "type": "password",
            "required": true
        },
        {
            "key": "oncore-client",
            "name": "OnCore Client ID",
            "type": "password",
            "required": true
        },
        {
            "key": "sample-val-desc",
            "name": "You must provide a protocol and an eIRB number which is used to collect fields from OnCore which are available for mapping data.",
            "type": "sub_settings",
            "sub_settings": [
                {
                    "key": "sample-protocol",
                    "name": "Sample Protocol Number",
                    "type": "text"
                },
                {
                    "key": "sample-eirb",
                    "name": "Sample eIRB Number",
                    "type": "text"
                }
            ],
            "required": true
        },
        {
            "key": "single-sync-pages",
            "name": "Select any pages that you would like to add an additional button to the \"actions\" header to synchronize an individual record. Default is \"demographics\" and \"regulatory\".",
            "type": "descriptive"
        },
        {
            "key": "sync-page",
            "name": "Select a form.",
            "type": "form-list",
            "repeatable": true
        },
        {
            "key": "field-mappings",
            "name": "DO NOT EDIT! OnCore Field Mappings",
            "type": "json",
            "hidden": true
        },
        {
            "key": "to-adjudicate",
            "name": "DO NOT EDIT! Records Requiring Adjudication",
            "type": "json",
            "hidden": true
        },
        {
            "key": "init",
            "name": "If false, run preconfigure.",
            "type": "checkbox",
            "hidden": true
        }
    ],
    "links": {
        "project": [
            {
                "name": "OnCore Field Mappings",
                "icon": "fas fa-right-left",
                "url": "pages/FieldMappings.php",
                "show-header-and-footer": true
            },
            {
                "name": "OnCore Sync Dashboard",
                "icon": "fas fa-arrows-rotate",
                "url": "pages/SyncDashboard.php",
                "show-header-and-footer": true
            },
            {
                "name": "API Test Page",
                "icon": "fas fa-paper-plane",
                "url": "pages/TestPage.php",
                "show-header-and-footer": true
            }
        ]
    },
    "api-actions": {
        "example-action": {
            "description": "This is an example of an action. auth below requires the endpoint to receive a CRS token",
            "access": ["auth"]
        }
    },
    "no-auth-pages": [
        "field-mapping",
        "sync-dashboard",
        "test-page"
    ]
}
